{
  "data_config": {
    "feature_dict": {
      "if_univariate": false,
      "if_trend": null,
      "has_timestamp": null,
      "if_season": null
    },
    "data_set_name": "large_forecast" 
  },

  "model_config": {
    "models": [
      {
        "model_name": "GCGNet",
        "models": [],
        "class": "ts_benchmark.baselines.GCGNet.model.GCGNet"
      }
    ],
    "recommend_model_hyper_params": {
      "input_chunk_length": 48,
      "output_chunk_length": 24,
      "add_relative_index": true,
      "norm": true
    }
  },

  "evaluation_config": {
    "metrics": "all",
    "strategy_args": {
      "strategy_name": "rolling_forecast",
      "horizon": 24,
      "pred_len": 24, 
      "tv_ratio": 0.95,
      "train_ratio_in_tv": {"__default__": 0.95},
      "stride": 24,
      "num_rollings": 1,        
      "seed": 2021,
      "deterministic": "efficient",
      "save_true_pred": true
    }
  },

  "model_hyper_params": {
    "batch_size": 4,          
    "d_ff": 128,
    "d_model": 64,
    "dropout": 0,
    "pred_len": 24,
    "loss": "MAE",
    "lr": 0.0001,
    "lradj": "type3",
    "n_heads": 2,
    "norm": true,
    "num_epochs": 1,            
    "patch_len": 24,
    "patience": 1,
    "rank": 2,
    "seq_len": 48
  },

  "report_config": {
    "aggregate_type": "mean",
    "report_metrics": ["mse_norm", "mae_norm", "rmse_norm", "mape_norm", "smape_norm", "wape_norm", "msmape_norm"],
    "fill_type": "mean_value",
    "null_value_threshold": "0.3"
  }
}